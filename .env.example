# Fourseat - Environment Variables

# Debate mode: "free" (no paid API calls) or "paid" (uses provider APIs)
DEBATE_MODE=free

# Optional paid API keys (only needed when DEBATE_MODE=paid)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
NIA_API_KEY=
NIA_BASE_URL=https://api.nia.ai/v1
NIA_MODEL=nia-1
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-70b

# Flask config
FLASK_SECRET_KEY=boardroom-ai-secret-change-this
FLASK_DEBUG=false
PORT=5000
# Optional runtime data directory (useful in serverless)
# FOURSEAT_DATA_DIR=/tmp/fourseat-data

# Waitlist email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=hello@fourseat.ai
WAITLIST_OWNER_EMAIL=you@company.com

# Billing (Stripe Checkout)
APP_BASE_URL=http://localhost:5000
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Fourseat Oracle (Stripe revenue intelligence)
# Required for live (non-demo) snapshot computation: same key as billing above.
# Required for the /api/stripe/webhook receiver (verifies Stripe-Signature header):
STRIPE_WEBHOOK_SECRET=
# Optional overrides:
# STRIPE_API_BASE=https://api.stripe.com
# STRIPE_API_VERSION=2024-06-20
# ORACLE_DB_URL=sqlite:///path/to/oracle.db

# ── Fourseat Company Brain ──────────────────────────────────────────────────
# Each connector below is optional. Without env vars, the Brain runs on a
# realistic demo dataset that already trips the closed-loop signal rules.

# Slack (OAuth bot token + channel IDs to ingest)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_IDS=
# Slack Events API webhook signing secret:
SLACK_SIGNING_SECRET=

# GitHub (PAT or fine-grained token + comma-separated owner/repo list)
GITHUB_TOKEN=
GITHUB_REPOS=
# GitHub webhook secret (verifies X-Hub-Signature-256):
GITHUB_WEBHOOK_SECRET=

# Linear (API key from Settings -> API)
LINEAR_API_KEY=
# Linear webhook secret (verifies linear-signature header):
LINEAR_WEBHOOK_SECRET=

# QuickBooks (OAuth access token + realm id from Intuit Developer Dashboard)
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=
# QUICKBOOKS_BASE_URL=https://quickbooks.api.intuit.com  # or sandbox URL

# Notion (Internal integration token)
NOTION_API_KEY=

# Optional Brain overrides:
# BRAIN_DB_URL=sqlite:///path/to/brain.db
# BRAIN_HTTP_TIMEOUT=12
# BRAIN_INGEST_LIMIT=60
