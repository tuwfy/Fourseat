# BoardRoom AI - Environment Variables
# Fill in your API keys below

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Flask config
FLASK_SECRET_KEY=boardroom-ai-secret-change-this
FLASK_DEBUG=false
PORT=5000

# Waitlist email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=hello@fourseat.ai
WAITLIST_OWNER_EMAIL=you@company.com
